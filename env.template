# GenAI Research Assistant Environment Configuration

# REQUIRED: Hugging Face Hub Token
# Get your token from: https://huggingface.co/settings/tokens
# Make sure to accept the LLaMA 3.1 model license first
HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here

# OPTIONAL: Model Configuration
# Default: meta-llama/Llama-3.1-8B-Instruct
# Other options: meta-llama/Llama-3.1-70B-Instruct (requires more resources)
MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# OPTIONAL: Development Configuration
# These are set automatically in docker-compose.yml
# VITE_API_URL=http://localhost:8000
# PORT=8080
